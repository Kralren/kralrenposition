<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>朋友印象备忘录 | 最终完整版</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        :root {
            --bg-page: #fef7e8;
            --card-bg: #ffffff;
            --text-main: #3a2c29;
            --text-soft: #8b7a6b;
            --border-light: #f0e5d8;
            --avatar-radius: 24px;
        }
        body { background: var(--bg-page); font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; color: var(--text-main); overflow-x: hidden; }
        .app { display: flex; min-height: 100vh; position: relative; }
        .drawer { position: fixed; top: 0; left: 0; width: 280px; height: 100%; background: var(--card-bg); box-shadow: 4px 0 24px rgba(0,0,0,0.06); z-index: 1000; transform: translateX(-100%); transition: transform 0.25s ease; display: flex; flex-direction: column; border-right: 1px solid var(--border-light); }
        .drawer.open { transform: translateX(0); }
        .drawer-header { padding: 32px 24px 20px; border-bottom: 1px solid var(--border-light); }
        .drawer-header h2 { font-size: 1.7rem; font-weight: 650; color: var(--text-main); }
        .group-list { flex: 1; padding: 20px 16px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; }
        .group-item { display: flex; align-items: center; justify-content: space-between; background: var(--bg-page); padding: 12px 16px; border-radius: 32px; cursor: pointer; border: 1px solid var(--border-light); }
        .group-item.active { background: var(--border-light); }
        .group-name { font-weight: 500; font-size: 1rem; color: var(--text-main); }
        .group-actions { display: flex; gap: 8px; }
        .icon-btn { background: transparent; border: none; font-size: 1rem; cursor: pointer; opacity: 0.6; padding: 4px 6px; border-radius: 30px; color: var(--text-main); }
        .add-group-drawer { margin: 16px 20px 30px; background: var(--border-light); border: none; padding: 12px; border-radius: 60px; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; color: var(--text-main); }
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.2); backdrop-filter: blur(2px); z-index: 999; visibility: hidden; opacity: 0; transition: 0.2s; }
        .overlay.show { visibility: visible; opacity: 1; }
        .main { flex: 1; padding: 20px 18px 40px; max-width: 720px; margin: 0 auto; width: 100%; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; gap: 12px; flex-wrap: wrap; }
        .menu-icon, .settings-icon { background: var(--card-bg); border: 1px solid var(--border-light); width: 48px; height: 48px; border-radius: 32px; font-size: 1.4rem; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-main); }
        .current-group-title { font-size: 1.8rem; font-weight: 650; color: var(--text-main); }
        .friends-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px 16px; margin-top: 16px; }
        .friend-card { text-align: center; cursor: pointer; transition: transform 0.1s; }
        .friend-card:active { transform: scale(0.97); }
        .avatar-square { width: 100%; aspect-ratio: 1/1; background: var(--border-light); border-radius: var(--avatar-radius); display: flex; align-items: center; justify-content: center; overflow: hidden; margin-bottom: 10px; border: 2px solid var(--card-bg); cursor: pointer; }
        .avatar-square img { width: 100%; height: 100%; object-fit: cover; }
        .avatar-placeholder { font-size: 2.4rem; color: var(--text-soft); }
        .friend-nickname { font-weight: 500; font-size: 0.85rem; background: var(--card-bg); display: inline-block; padding: 4px 10px; border-radius: 40px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-main); }
        .add-card .avatar-square { background: var(--card-bg); border: 1.5px dashed var(--border-light); }
        .plus-large { font-size: 2.2rem; color: var(--text-soft); }
        .empty-group { text-align: center; padding: 56px 20px; color: var(--text-soft); }
        .settings-panel { position: fixed; top: 0; right: -100%; width: 300px; height: 100%; background: var(--card-bg); box-shadow: -4px 0 20px rgba(0,0,0,0.1); z-index: 1200; transition: right 0.25s ease; padding: 28px 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 24px; border-left: 1px solid var(--border-light); }
        .settings-panel.open { right: 0; }
        .settings-section { border-bottom: 1px solid var(--border-light); padding-bottom: 18px; }
        .settings-title { font-weight: 600; margin-bottom: 14px; font-size: 1rem; color: var(--text-main); }
        .example-themes { display: flex; gap: 16px; margin-bottom: 20px; flex-wrap: wrap; }
        .example-btn { padding: 8px 16px; border-radius: 40px; background: var(--border-light); cursor: pointer; font-size: 0.8rem; color: var(--text-main); border: none; }
        .color-row { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
        .color-label { width: 70px; font-size: 0.8rem; color: var(--text-main); }
        .color-input { width: 50px; height: 40px; border: 1px solid var(--border-light); border-radius: 12px; cursor: pointer; background: var(--bg-page); }
        .radius-slider { width: 100%; margin-top: 8px; }
        .close-settings { margin-top: 20px; background: var(--border-light); border: none; padding: 10px; border-radius: 60px; cursor: pointer; color: var(--text-main); }
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); backdrop-filter: blur(6px); display: flex; align-items: center; justify-content: center; z-index: 1100; visibility: hidden; opacity: 0; transition: 0.2s; }
        .modal.active { visibility: visible; opacity: 1; }
        .modal-box { background: var(--card-bg); width: 90%; max-width: 500px; border-radius: 44px; padding: 24px; max-height: 85vh; overflow-y: auto; color: var(--text-main); }
        .profile-header { display: flex; gap: 18px; margin-bottom: 20px; align-items: center; }
        .profile-avatar-lg { width: 80px; height: 80px; border-radius: var(--avatar-radius); object-fit: cover; background: var(--border-light); cursor: pointer; border: 2px solid var(--card-bg); }
        .name-fields { flex: 1; }
        .name-fields input { width: 100%; margin-bottom: 8px; border: 1.5px solid var(--border-light); border-radius: 28px; padding: 8px 14px; font-size: 0.9rem; background: var(--card-bg); color: var(--text-main); }
        .detail-textarea { margin-top: 16px; }
        .detail-textarea label { font-weight: 600; font-size: 0.75rem; color: var(--text-soft); display: block; margin-bottom: 6px; }
        textarea { width: 100%; border: 1.5px solid var(--border-light); border-radius: 24px; padding: 12px; font-family: inherit; font-size: 0.85rem; resize: vertical; background: var(--card-bg); color: var(--text-main); }
        .img-upload-row { display: flex; gap: 12px; margin: 16px 0 10px; }
        .img-btn { background: var(--border-light); border: none; padding: 6px 14px; border-radius: 40px; font-size: 0.7rem; cursor: pointer; color: var(--text-main); }
        .photo-wall { margin-top: 20px; border-top: 1px solid var(--border-light); padding-top: 16px; }
        .photo-title { font-weight: 600; font-size: 0.8rem; margin-bottom: 12px; color: var(--text-main); }
        .photo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
        .photo-item { position: relative; aspect-ratio: 1/1; background: var(--border-light); border-radius: 16px; overflow: hidden; cursor: pointer; }
        .photo-item img { width: 100%; height: 100%; object-fit: cover; }
        .photo-delete { position: absolute; top: 4px; right: 4px; background: rgba(0,0,0,0.6); color: white; width: 22px; height: 22px; border-radius: 30px; display: flex; align-items: center; justify-content: center; font-size: 12px; cursor: pointer; z-index: 2; }
        .add-photo { display: flex; align-items: center; justify-content: center; background: var(--border-light); font-size: 28px; color: var(--text-soft); cursor: pointer; }
        .modal-buttons { display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap; }
        .btn-save, .btn-delete, .btn-close { border: none; padding: 10px 0; border-radius: 60px; font-weight: 600; flex: 1; cursor: pointer; }
        .btn-save { background: #cfe2c0; color: #3c5e2b; }
        .btn-delete { background: #ffe0d6; color: #bc6f50; }
        .btn-close { background: var(--border-light); color: var(--text-main); }
        .image-viewer { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 2000; display: flex; align-items: center; justify-content: center; visibility: hidden; opacity: 0; transition: 0.2s; cursor: pointer; }
        .image-viewer.active { visibility: visible; opacity: 1; }
        .image-viewer img { max-width: 90%; max-height: 90%; object-fit: contain; border-radius: 16px; }
        @media (max-width: 500px) { .friends-grid { gap: 16px 12px; } .friend-nickname { font-size: 0.75rem; } .profile-avatar-lg { width: 70px; height: 70px; } }
    </style>
</head>
<body>
<div class="app">
    <div class="drawer" id="drawer">
        <div class="drawer-header"><h2>📔 群组</h2><p>切换 / 管理</p></div>
        <div class="group-list" id="groupList"></div>
        <button class="add-group-drawer" id="addGroupDrawerBtn">+ 新建群组</button>
    </div>
    <div class="overlay" id="overlay"></div>
    <div class="main">
        <div class="top-bar">
            <button class="menu-icon" id="menuBtn">☰</button>
            <span class="current-group-title" id="currentGroupTitle">挚友圈</span>
            <button class="settings-icon" id="openSettingsBtn">⚙️</button>
        </div>
        <div id="friendsGrid" class="friends-grid"></div>
    </div>
    <div id="settingsPanel" class="settings-panel">
        <h3 style="margin-bottom:8px;color:var(--text-main);">外观定制</h3>
        <div class="settings-section"><div class="settings-title">🎨 快速配色方案</div><div class="example-themes"><button class="example-btn" data-preset="macaron">马卡龙</button><button class="example-btn" data-preset="dark">深色质感</button><button class="example-btn" data-preset="light">清新浅色</button></div></div>
        <div class="settings-section"><div class="settings-title">🎨 自定义颜色</div><div class="color-row"><span class="color-label">背景色</span><input type="color" id="bgColorPicker" class="color-input" value="#fef7e8"></div><div class="color-row"><span class="color-label">卡片色</span><input type="color" id="cardColorPicker" class="color-input" value="#ffffff"></div><div class="color-row"><span class="color-label">文字色</span><input type="color" id="textColorPicker" class="color-input" value="#3a2c29"></div></div>
        <div class="settings-section"><div class="settings-title">🔘 头像圆角</div><input type="range" id="radiusSlider" min="8" max="50" step="2" value="24" style="width:100%"><span id="radiusValue" style="color:var(--text-main);">24px</span></div>
        <button id="closeSettingsBtn" class="close-settings">关闭设置</button>
    </div>
</div>
<div id="friendModal" class="modal"><div class="modal-box" id="modalContent"></div></div>
<div id="imageViewer" class="image-viewer"><img id="viewerImg" src=""></div>
<script>
(function(){
    let groups = [];
    let currentGroupId = null;
    function escapeHtml(str){ if(!str) return ''; return str.replace(/[&<>]/g, function(m){ if(m==='&') return '&amp;'; if(m==='<') return '&lt;'; if(m==='>') return '&gt;'; return m; }); }
    function adjustColor(hex, percent){ if(!hex) return '#e0d5c8'; let r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16); r=Math.min(255,Math.max(0,r+percent)); g=Math.min(255,Math.max(0,g+percent)); b=Math.min(255,Math.max(0,b+percent)); return '#'+((1<<24)+(r<<16)+(g<<8)+b).toString(16).slice(1); }
    function updateColors(bg,card,text){ document.documentElement.style.setProperty('--bg-page',bg); document.documentElement.style.setProperty('--card-bg',card); document.documentElement.style.setProperty('--text-main',text); document.documentElement.style.setProperty('--border-light',adjustColor(card,-20)); document.documentElement.style.setProperty('--text-soft',adjustColor(text,30)); localStorage.setItem('customBg',bg); localStorage.setItem('customCard',card); localStorage.setItem('customText',text); }
    function loadSavedColors(){ let bg=localStorage.getItem('customBg')||'#fef7e8',card=localStorage.getItem('customCard')||'#ffffff',text=localStorage.getItem('customText')||'#3a2c29'; document.getElementById('bgColorPicker').value=bg; document.getElementById('cardColorPicker').value=card; document.getElementById('textColorPicker').value=text; updateColors(bg,card,text); }
    function setPreset(name){ if(name==='macaron') updateColors('#fef7e8','#ffffff','#3a2c29'); if(name==='dark') updateColors('#1e2a2e','#2d3e42','#e8f0f2'); if(name==='light') updateColors('#f0f4f8','#ffffff','#2c3e50'); let bg=getComputedStyle(document.documentElement).getPropertyValue('--bg-page').trim(),card=getComputedStyle(document.documentElement).getPropertyValue('--card-bg').trim(),text=getComputedStyle(document.documentElement).getPropertyValue('--text-main').trim(); document.getElementById('bgColorPicker').value=bg; document.getElementById('cardColorPicker').value=card; document.getElementById('textColorPicker').value=text; }
    let currentRadius=parseInt(localStorage.getItem('avatarRadius')||'24'); function setAvatarRadius(val){ document.documentElement.style.setProperty('--avatar-radius',val+'px'); localStorage.setItem('avatarRadius',val); document.getElementById('radiusValue').innerText=val+'px'; }
    function saveData(){ localStorage.setItem('FriendGroupsDataFinal',JSON.stringify(groups)); }
    function initDefaultData(){ groups=[{id:'group1',name:'🌟 挚友圈',friends:[{id:'f1',name:'鑫鑫',nickname:'鑫宝',impression:'永远的小太阳',personality:'开朗仗义',avatarDataUrl:'',photos:[]},{id:'f2',name:'悦悦',nickname:'小悦',impression:'温柔细腻',personality:'善解人意',avatarDataUrl:'',photos:[]},{id:'f3',name:'贝贝',nickname:'贝儿',impression:'古灵精怪',personality:'幽默',avatarDataUrl:'',photos:[]},{id:'f4',name:'小艾',nickname:'艾艾',impression:'自律上进',personality:'沉稳',avatarDataUrl:'',photos:[]},{id:'f5',name:'乐乐',nickname:'乐宝',impression:'开心果',personality:'活泼',avatarDataUrl:'',photos:[]}]},{id:'group2',name:'🎓 同窗好友',friends:[{id:'f6',name:'周宁',nickname:'宁宁',impression:'学霸咖啡控',personality:'专注',avatarDataUrl:'',photos:[]}]}]; }
    function loadData(){ let raw=localStorage.getItem('FriendGroupsDataFinal'); if(raw){ try{ groups=JSON.parse(raw); groups.forEach(g=>{ if(!g.friends) g.friends=[]; g.friends.forEach(f=>{ if(!f.id) f.id=Date.now()+Math.random()+''; if(!f.photos) f.photos=[]; }); }); }catch(e){ initDefaultData(); } }else{ initDefaultData(); } if(!currentGroupId && groups.length) currentGroupId=groups[0].id; renderAll(); }
    function renderDrawer(){ let container=document.getElementById('groupList'); if(!container) return; container.innerHTML=''; groups.forEach(group=>{ let div=document.createElement('div'); div.className=`group-item ${currentGroupId===group.id?'active':''}`; div.innerHTML=`<span class="group-name">${escapeHtml(group.name)}</span><div class="group-actions"><button class="icon-btn edit-group" data-id="${group.id}">✏️</button><button class="icon-btn del-group" data-id="${group.id}">🗑️</button></div>`; div.addEventListener('click',(e)=>{ if(e.target.classList.contains('icon-btn')) return; currentGroupId=group.id; renderAll(); closeDrawer(); }); container.appendChild(div); }); document.querySelectorAll('.edit-group').forEach(btn=>{ btn.onclick=(e)=>{ e.stopPropagation(); let gid=btn.getAttribute('data-id'); let g=groups.find(g=>g.id===gid); if(g){ let n=prompt('修改群组名',g.name); if(n && n.trim()){ g.name=n.trim(); saveData(); renderAll(); } } }; }); document.querySelectorAll('.del-group').forEach(btn=>{ btn.onclick=(e)=>{ e.stopPropagation(); let gid=btn.getAttribute('data-id'); if(groups.length===1){ alert('至少保留一个群组'); return; } if(confirm('删除群组会清空所有好友')){ groups=groups.filter(g=>g.id!==gid); if(currentGroupId===gid) currentGroupId=groups[0].id; saveData(); renderAll(); } }; }); }
    function renderMain(){ let container=document.getElementById('friendsGrid'); let group=groups.find(g=>g.id===currentGroupId); if(!group){ container.innerHTML='<div class="empty-group">✨ 请先在左侧添加群组</div>'; document.getElementById('currentGroupTitle').innerText='未选择'; return; } document.getElementById('currentGroupTitle').innerText=group.name; container.innerHTML=''; group.friends.forEach(friend=>{ let card=document.createElement('div'); card.className='friend-card'; let hasAvatar=friend.avatarDataUrl && friend.avatarDataUrl!==''; card.innerHTML=`<div class="avatar-square" data-friend-id="${friend.id}" data-group-id="${group.id}">${hasAvatar?`<img src="${friend.avatarDataUrl}">`:`<div class="avatar-placeholder">📷</div>`}</div><div class="friend-nickname">${escapeHtml(friend.nickname||friend.name)}</div>`; let avatarDiv=card.querySelector('.avatar-square'); avatarDiv.addEventListener('click',(e)=>{ e.stopPropagation(); openImageUploadForFriend(friend.id,group.id); }); card.addEventListener('click',(e)=>{ if(e.target.closest('.avatar-square')) return; openFriendDetailModal(friend,group.id); }); container.appendChild(card); }); let addCard=document.createElement('div'); addCard.className='friend-card add-card'; addCard.innerHTML=`<div class="avatar-square"><div class="plus-large">+</div></div><div class="friend-nickname">添加朋友</div>`; addCard.addEventListener('click',()=>openFriendDetailModal(null,group.id)); container.appendChild(addCard); }
    function openImageUploadForFriend(friendId,groupId){ let group=groups.find(g=>g.id===groupId); let friend=group?.friends.find(f=>f.id===friendId); if(!friend) return; let input=document.createElement('input'); input.type='file'; input.accept='image/*'; input.onchange=(e)=>{ let file=e.target.files[0]; if(file && file.type.startsWith('image/')){ let reader=new FileReader(); reader.onload=(ev)=>{ friend.avatarDataUrl=ev.target.result; saveData(); renderMain(); }; reader.readAsDataURL(file); }else alert('请选择图片'); }; input.click(); }
    function addPhotoToFriend(friend,groupId){ let input=document.createElement('input'); input.type='file'; input.accept='image/*'; input.onchange=(e)=>{ let file=e.target.files[0]; if(file && file.type.startsWith('image/')){ let reader=new FileReader(); reader.onload=(ev)=>{ if(!friend.photos) friend.photos=[]; friend.photos.push(ev.target.result); saveData(); openFriendDetailModal(friend,groupId); }; reader.readAsDataURL(file); }else alert('请选择图片'); }; input.click(); }
    function deletePhotoFromFriend(friend,groupId,index){ if(friend.photos && friend.photos[index]){ friend.photos.splice(index,1); saveData(); openFriendDetailModal(friend,groupId); } }
    function showImageViewer(src){ let viewer=document.getElementById('imageViewer'); let viewerImg=document.getElementById('viewerImg'); viewerImg.src=src; viewer.classList.add('active'); viewer.onclick=()=>viewer.classList.remove('active'); }
    let currentModalGroup=null, editingFriend=null, tempAvatarModal=null;
    function openFriendDetailModal(friend,groupId){ let isNew=!friend; currentModalGroup=groupId; editingFriend=isNew?null:{...friend}; tempAvatarModal=isNew?null:(friend?.avatarDataUrl||null); let modal=document.getElementById('friendModal'); let modalC=document.getElementById('modalContent'); let photoHtml=!isNew?`<div class="photo-wall"><div class="photo-title">📸 照片墙 (点击图片放大)</div><div class="photo-grid" id="photoGrid">${(friend.photos||[]).map((p,idx)=>`<div class="photo-item" data-img-src="${p}"><img src="${p}" alt="照片"><div class="photo-delete" data-index="${idx}">✕</div></div>`).join('')}<div class="photo-item add-photo" id="addPhotoBtn">+</div></div></div>`:'';
        modalC.innerHTML=`<div class="profile-header"><img id="modalAvatarPreview" class="profile-avatar-lg" src="${!isNew && friend.avatarDataUrl?friend.avatarDataUrl:''}" alt="头像" style="cursor:pointer;"><div class="name-fields"><input id="editName" placeholder="大名 *" value="${isNew?'':escapeHtml(friend.name)}"><input id="editNickname" placeholder="小名 / 昵称" value="${isNew?'':escapeHtml(friend.nickname||'')}"></div></div><div class="img-upload-row"><button class="img-btn" id="uploadModalBtn">📷 更改头像</button><button class="img-btn clear-btn" id="clearModalBtn">🗑️ 清除头像</button></div><div class="detail-textarea"><label>💬 我对你的印象</label><textarea id="editImpression" rows="2" placeholder="写一写难忘的故事...">${isNew?'':escapeHtml(friend.impression||'')}</textarea></div><div class="detail-textarea"><label>🎭 性格·特点</label><textarea id="editPersonality" rows="2" placeholder="温暖、幽默...">${isNew?'':escapeHtml(friend.personality||'')}</textarea></div>${photoHtml}<div class="modal-buttons"><button class="btn-save" id="saveModalBtn">保存</button>${!isNew?'<button class="btn-delete" id="deleteModalBtn">删除好友</button>':''}<button class="btn-close" id="closeModalBtn">取消</button></div>`;
        modal.classList.add('active');
        let preview=modalC.querySelector('#modalAvatarPreview'), uploadBtn=modalC.querySelector('#uploadModalBtn'), clearBtn=modalC.querySelector('#clearModalBtn');
        let fileInput=document.createElement('input'); fileInput.type='file'; fileInput.accept='image/*';
        let pick=()=>fileInput.click();
        if(preview) preview.addEventListener('click',pick);
        if(uploadBtn) uploadBtn.addEventListener('click',pick);
        fileInput.onchange=(e)=>{ let file=e.target.files[0]; if(file && file.type.startsWith('image/')){ let reader=new FileReader(); reader.onload=(ev)=>{ if(preview) preview.src=ev.target.result; tempAvatarModal=ev.target.result; }; reader.readAsDataURL(file); }else alert('请选择图片'); };
        if(clearBtn){ clearBtn.onclick=()=>{ if(preview) preview.src=''; tempAvatarModal=''; fileInput.value=''; }; }
        if(!isNew){ let addPhotoBtn=modalC.querySelector('#addPhotoBtn'); if(addPhotoBtn) addPhotoBtn.onclick=()=>addPhotoToFriend(friend,groupId); let photoItems=modalC.querySelectorAll('.photo-item'); photoItems.forEach(item=>{ let img=item.querySelector('img'); let delBtn=item.querySelector('.photo-delete'); if(img && !delBtn){ item.onclick=(e)=>{ if(e.target.classList.contains('photo-delete')) return; let src=item.getAttribute('data-img-src')||img.src; showImageViewer(src); }; } if(delBtn){ delBtn.onclick=(e)=>{ e.stopPropagation(); deletePhotoFromFriend(friend,groupId,parseInt(delBtn.getAttribute('data-index'))); }; } }); }
        let saveBtn=modalC.querySelector('#saveModalBtn'); saveBtn.onclick=()=>{ let nameVal=modalC.querySelector('#editName').value.trim(); if(!nameVal){ alert('请填写大名'); return; } let nicknameVal=modalC.querySelector('#editNickname').value; let impressionVal=modalC.querySelector('#editImpression').value; let personalityVal=modalC.querySelector('#editPersonality').value; let finalAvatar=(tempAvatarModal!==undefined && tempAvatarModal!==null)?tempAvatarModal:(isNew?'':(editingFriend?.avatarDataUrl||'')); let targetGroup=groups.find(g=>g.id===currentModalGroup); if(!targetGroup){ alert('群组不存在'); modal.classList.remove('active'); return; } if(isNew){ targetGroup.friends.push({ id:Date.now()+'-'+Math.random(), name:nameVal, nickname:nicknameVal||'', impression:impressionVal||'', personality:personalityVal||'', avatarDataUrl:finalAvatar||'', photos:[] }); }else{ let idx=targetGroup.friends.findIndex(f=>f.id===editingFriend.id); if(idx!==-1){ targetGroup.friends[idx].name=nameVal; targetGroup.friends[idx].nickname=nicknameVal||''; targetGroup.friends[idx].impression=impressionVal||''; targetGroup.friends[idx].personality=personalityVal||''; targetGroup.friends[idx].avatarDataUrl=finalAvatar||''; }else{ alert('好友不存在'); modal.classList.remove('active'); return; } } saveData(); modal.classList.remove('active'); renderAll(); };
        let closeBtn=modalC.querySelector('#closeModalBtn'); if(closeBtn) closeBtn.onclick=()=>modal.classList.remove('active');
        let delBtn=modalC.querySelector('#deleteModalBtn'); if(delBtn && !isNew){ delBtn.onclick=()=>{ if(confirm(`删除好友“${editingFriend.name}”?`)){ let tGroup=groups.find(g=>g.id===currentModalGroup); if(tGroup){ tGroup.friends=tGroup.friends.filter(f=>f.id!==editingFriend.id); saveData(); renderAll(); } modal.classList.remove('active'); } }; }
        modal.onclick=(e)=>{ if(e.target===modal) modal.classList.remove('active'); };
    }
    function renderAll(){ renderDrawer(); renderMain(); }
    function addNewGroup(){ let name=prompt('群组名称','🌸 新群组'); if(!name) name='好友圈'; name=name.trim()||'好友圈'; groups.push({ id:'g_'+Date.now()+'_'+Math.random(), name:name, friends:[] }); currentGroupId=groups[groups.length-1].id; saveData(); renderAll(); closeDrawer(); }
    function closeDrawer(){ document.getElementById('drawer').classList.remove('open'); document.getElementById('overlay').classList.remove('show'); }
    function openDrawer(){ document.getElementById('drawer').classList.add('open'); document.getElementById('overlay').classList.add('show'); }
    document.getElementById('menuBtn').onclick=openDrawer;
    document.getElementById('overlay').onclick=closeDrawer;
    document.getElementById('addGroupDrawerBtn').onclick=()=>{ addNewGroup(); closeDrawer(); };
    document.getElementById('openSettingsBtn').onclick=()=>document.getElementById('settingsPanel').classList.add('open');
    document.getElementById('closeSettingsBtn').onclick=()=>document.getElementById('settingsPanel').classList.remove('open');
    document.getElementById('radiusSlider').oninput=(e)=>setAvatarRadius(e.target.value);
    setAvatarRadius(currentRadius);
    document.querySelectorAll('.example-btn').forEach(btn=>btn.onclick=()=>setPreset(btn.getAttribute('data-preset')));
    document.getElementById('bgColorPicker').onchange=(e)=>updateColors(e.target.value,document.getElementById('cardColorPicker').value,document.getElementById('textColorPicker').value);
    document.getElementById('cardColorPicker').onchange=(e)=>updateColors(document.getElementById('bgColorPicker').value,e.target.value,document.getElementById('textColorPicker').value);
    document.getElementById('textColorPicker').onchange=(e)=>updateColors(document.getElementById('bgColorPicker').value,document.getElementById('cardColorPicker').value,e.target.value);
    loadSavedColors();
    loadData();
})();
</script>
</body>
